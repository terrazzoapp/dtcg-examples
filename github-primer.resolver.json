{
  "name": "GitHub Primer",
  "version": "2025.10",
  "sets": {
    "base": {
      "sources": [
        { "$ref": "./github-primer/base/color/light/light.json" },
        { "$ref": "./github-primer/base/color/light/display-light.json" },
        { "$ref": "./github-primer/base/motion/easing.json" },
        { "$ref": "./github-primer/base/motion/timing.json" },
        { "$ref": "./github-primer/base/size/size.json" },
        { "$ref": "./github-primer/base/size/typography/typography.json" }
      ]
    },
    "functional": {
      "sources": [
        { "$ref": "./github-primer/functional/border/border.json" },
        { "$ref": "./github-primer/functional/color/bgColor.json" },
        { "$ref": "./github-primer/functional/color/borderColor.json" },
        { "$ref": "./github-primer/functional/color/control.json" },
        { "$ref": "./github-primer/functional/color/data-vfs.json" },
        { "$ref": "./github-primer/functional/color/display.json" },
        { "$ref": "./github-primer/functional/color/fgColor.json" },
        { "$ref": "./github-primer/functional/color/focus.json" },
        { "$ref": "./github-primer/functional/color/selection.json" },
        { "$ref": "./github-primer/functional/color/syntax.json" }
        { "$ref": "./github-primer/functional/shadow/shadow.json" }
        { "$ref": "./github-primer/functional/size/border.json" }
        { "$ref": "./github-primer/functional/size/breakpoints.json" }
        { "$ref": "./github-primer/functional/size/size.json" }
        { "$ref": "./github-primer/functional/size/viewport.json" }
        { "$ref": "./github-primer/functional/typography/typography.json" }
      ]
    }
  },
  "modifiers": {
    "theme": {
      "contexts": {
        "light": [{ "$ref": "./github-primer/base/color/light/light.json" }],
        "light-hc": [
          { "$ref": "./github-primer/base/color/light/light.json" },
          {
            "$ref": "./github-primer/base/color/light/light.high-contrast.json"
          }
        ],
        "dark": [{ "$ref": "./github-primer/base/color/dark/dark.json" }],
        "dark-hc": [
          { "$ref": "./github-primer/base/color/dark/dark.high-contrast.json" }
        ]
      },
      "default": "light"
    },
    "size": {
      "contexts": {
        "default": [],
        "coarse": [{ "$ref": "./github-primer/functional/size/size-coarse.json" }],
        "fine": [{ "$ref": "./github-primer/functional/size/size-fine.json" }]
      },
      "default": "default"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/base" },
    { "$ref": "#/modifiers/theme" },
    { "$ref": "#/modifiers/size" }
  ]
}
