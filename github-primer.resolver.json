{
  "$schema": "https://www.designtokens.org/schemas/2025.10/resolver.json",
  "name": "GitHub Primer",
  "version": "2025.10",
  "resolutionOrder": [{ "$ref": "#/sets/base" }, { "$ref": "#/sets/functional" }, { "$ref": "#/sets/component" }, { "$ref": "#/modifiers/theme" }, { "$ref": "#/modifiers/size" }],
  "sets": {
    "base": {
      "sources": [
        { "$ref": "./github-primer/base/color/light/light.tokens.json" },
        { "$ref": "./github-primer/base/color/light/display-light.tokens.json" },
        { "$ref": "./github-primer/base/motion/easing.tokens.json" },
        { "$ref": "./github-primer/base/motion/timing.tokens.json" },
        { "$ref": "./github-primer/base/size/size.tokens.json" },
        { "$ref": "./github-primer/base/typography/typography.tokens.json" }
      ]
    },
    "functional": {
      "sources": [
        { "$ref": "./github-primer/functional/border/border.tokens.json" },
        { "$ref": "./github-primer/functional/color/bgColor.tokens.json" },
        { "$ref": "./github-primer/functional/color/borderColor.tokens.json" },
        { "$ref": "./github-primer/functional/color/control.tokens.json" },
        { "$ref": "./github-primer/functional/color/data-vis.tokens.json" },
        { "$ref": "./github-primer/functional/color/display.tokens.json" },
        { "$ref": "./github-primer/functional/color/fgColor.tokens.json" },
        { "$ref": "./github-primer/functional/color/focus.tokens.json" },
        { "$ref": "./github-primer/functional/color/selection.tokens.json" },
        { "$ref": "./github-primer/functional/color/syntax.tokens.json" },
        { "$ref": "./github-primer/functional/shadow/shadow.tokens.json" },
        { "$ref": "./github-primer/functional/size/border.tokens.json" },
        { "$ref": "./github-primer/functional/size/breakpoints.tokens.json" },
        { "$ref": "./github-primer/functional/size/size.tokens.json" },
        { "$ref": "./github-primer/functional/typography/typography.tokens.json" }
      ]
    },
    "component": {
      "sources": [
        { "$ref": "./github-primer/component/avatar.tokens.json" },
        { "$ref": "./github-primer/component/button.tokens.json" },
        { "$ref": "./github-primer/component/card.tokens.json" },
        { "$ref": "./github-primer/component/codeMirror.tokens.json" },
        { "$ref": "./github-primer/component/contribution.tokens.json" },
        { "$ref": "./github-primer/component/counter.tokens.json" },
        { "$ref": "./github-primer/component/dashboard.tokens.json" },
        { "$ref": "./github-primer/component/diffBlob.tokens.json" },
        { "$ref": "./github-primer/component/header.tokens.json" },
        { "$ref": "./github-primer/component/headerSerach.tokens.json" },
        { "$ref": "./github-primer/component/highlight.tokens.json" },
        { "$ref": "./github-primer/component/label.tokens.json" },
        { "$ref": "./github-primer/component/menu.tokens.json" },
        { "$ref": "./github-primer/component/overlay.tokens.json" },
        { "$ref": "./github-primer/component/page.tokens.json" },
        { "$ref": "./github-primer/component/progressBar.tokens.json" },
        { "$ref": "./github-primer/component/reactionButton.tokens.json" },
        { "$ref": "./github-primer/component/selectMenu.tokens.json" },
        { "$ref": "./github-primer/component/sideNav.tokens.json" },
        { "$ref": "./github-primer/component/skeletonLoader.tokens.json" },
        { "$ref": "./github-primer/component/timelineBadge.tokens.json" },
        { "$ref": "./github-primer/component/tooltip.tokens.json" },
        { "$ref": "./github-primer/component/topicTag.tokens.json" },
        { "$ref": "./github-primer/component/treeView.tokens.json" },
        { "$ref": "./github-primer/component/underlineNav.tokens.json" }
      ]
    }
  },
  "modifiers": {
    "theme": {
      "contexts": {
        "light": [
          { "$ref": "./github-primer/base/color/light/light.tokens.json" }
        ],
        "light-hc": [
          { "$ref": "./github-primer/base/color/light/light.tokens.json" },
          { "$ref": "./github-primer/base/color/light/light.high-contrast.tokens.json" }
        ],
        "dark": [
          { "$ref": "./github-primer/base/color/dark/dark.tokens.json" }
        ],
        "dark-hc": [
          { "$ref": "./github-primer/base/color/dark/dark.tokens.json" },
          { "$ref": "./github-primer/base/color/dark/dark.high-contrast.tokens.json" }
        ]
      },
      "default": "light"
    },
    "size": {
      "contexts": {
        "default": [],
        "coarse": [{ "$ref": "./github-primer/functional/size/size-coarse.tokens.json" }],
        "fine": [{ "$ref": "./github-primer/functional/size/size-fine.tokens.json" }]
      },
      "default": "default"
    }
  }
}
