{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "card": {
    "bgColor": {
      "$value": "{bgColor.default}",
      "$type": "color",
      "$extensions": {
        "org.primer.figma": {
          "collection": "mode",
          "group": "component",
          "scopes": [
            "bgColor"
          ]
        },
        "org.primer.overrides": {
          "dark": "{bgColor.muted}"
        }
      }
    }
  }
}