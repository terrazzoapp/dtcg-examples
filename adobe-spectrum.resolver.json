{
  "name": "Adobe Spectrum",
  "version": "2025.10",
  "sets": {
    "base": {
      "sources": [{ "$ref": "./adobe-spectrum/base.json" }]
    }
  },
  "modifiers": {
    "theme": {
      "contexts": {
        "light": [{ "$ref": "./adobe-spectrum/theme-light.json" }],
        "dark": [{ "$ref": "./adobe-spectrum/theme-dark.json" }]
      }
    },
    "size": {
      "contexts": {
        "desktop": [{ "$ref": "./adobe-spectrum/size-desktop.json" }],
        "mobile": [{ "$ref": "./adobe-spectrum/size-mobile.json" }]
      }
    }
  },
  "resolutionOrder": [{ "$ref": "#/sets/base" }, { "$ref": "#/modifiers/theme" }, { "$ref": "#/modifiers/size" }]
}
