    "dtcg",
    "w3c",
    "carbon",
    "polaris",
    "primer",
    "sds",
    "spectrum"
  ],
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Drew Powers",
    "email": "drew@pow.rs"
  },
  "packageManager": "pnpm@10.28.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrazzoapp/dtcg-examples"
  },
  "scripts": {
    "lint": "pnpm run --parallel \"/^lint:/\"",
    "lint:adobe": "tz check adobe-spectrum.resolver.json",
    "lint:apple": "tz check apple-hig.resolver.json",
    "lint:figma": "tz check figma-sds.resolver.json",
    "lint:github": "tz check github-primer.resolver.json",
    "lint:ibm": "tz check ibm-carbon.resolver.json",
    "lint:ms": "tz check microsoft-fluent.resolver.json",
    "lint:shopify": "tz check shopify-polaris.resolver.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@carbon/colors": "^11.45.0",
    "@carbon/layout": "^11.46.0",
    "@carbon/type": "^11.52.0",
    "@fluentui/theme": "^2.7.2",
    "@terrazzo/cli": "^0.8.1",
    "@terrazzo/parser": "^0.8.1",
    "@types/node": "^24.10.8",
    "colorjs.io": "^0.6.0",
    "degit": "^2.8.4",
    "json5": "^2.2.3",
    "tinyglobby": "^0.2.15"
  }
}
